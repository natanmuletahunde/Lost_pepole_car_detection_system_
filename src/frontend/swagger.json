          "timestamp": { "type": "string", "format": "date-time" },
          "userAgent": { "type": "string" },
          "ipAddress": { "type": "string" }
        }
      },
      "ReportedBy": {
        "type": "object",
        "properties": {
          "userId": { "type": "string" },
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "email": { "type": "string" },
