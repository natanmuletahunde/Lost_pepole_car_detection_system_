          "brand": { "type": "string" },
          "model": { "type": "string" },
          "submodel": { "type": "string" },
          "color": { "type": "string" },
          "vehicleDescription": { "type": "string" },
          "plateType": { "type": "string" },
          "region": { "type": "string" },
          "code": { "type": "string" },
          "plateNumber": { "type": "string" },
          "location": { "type": "string" },
          "lastSeenDate": { "type": "string", "format": "date" },
          "lastSeenTime": { "type": "string" },
          "status": { "type": "string" },
          "reportDate": { "type": "string", "format": "date-time" },
          "lastUpdated": { "type": "string", "format": "date-time" },
          "verified": { "type": "boolean" },
          "latitude": { "type": "string" },
          "longitude": { "type": "string" },
          "reportedBy": { "$ref": "#/components/schemas/ReportedBy" }
        }
      },
      "Sighting": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "enum": ["Person", "Vehicle"] },
          "name": { "type": "string" },
          "plateNumber": { "type": "string" },
          "description": { "type": "string" },
          "location": { "type": "string" },
          "date": { "type": "string", "format": "date" },
          "time": { "type": "string" },
          "latitude": { "type": "number" },
          "longitude": { "type": "number" },
          "originalCaseId": { "type": "string" },
          "status": { "type": "string" },
          "reportDate": { "type": "string", "format": "date-time" },
          "reportedBy": { "$ref": "#/components/schemas/ReportedBy" }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "phone": { "type": "string" },
          "password": { "type": "string" },
          "role": { "type": "string", "enum": ["user", "admin"] },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" },
          "isActive": { "type": "boolean" },
          "lastLogin": { "type": "string", "format": "date-time" }
        }
      },
      "GPSDevice": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "serialNumber": { "type": "string" },
          "assignedTo": { "type": "string" },
          "status": { "type": "string", "enum": ["active", "inactive", "low_battery"] },
